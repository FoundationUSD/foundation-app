# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Vault Authority (base58 secret key — NEVER commit)
VAULT_AUTHORITY_SECRET=

# Vault Mints (set after running scripts/setup-vaults.ts)
NEXT_PUBLIC_VAULT_APOLLO_MINT=
NEXT_PUBLIC_VAULT_BUILD_MINT=
NEXT_PUBLIC_VAULT_SCOPE_MINT=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin
ADMIN_API_KEY=

# X — OAuth 2.0 for FCY waitlist sign-in via better-auth
# Get these from console.x.com → App → Keys & tokens → OAuth 2.0 Client
# Add this callback URL in the X app settings: {BETTER_AUTH_URL}/api/auth/callback/twitter
# (callback path stays /twitter — that's better-auth's internal provider id)
X_CLIENT_ID=
X_CLIENT_SECRET=
